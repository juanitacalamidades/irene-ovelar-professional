---
---

<header class="relative top-0 left-0 w-full bg-white z-50 border-b border-gray-100">
  <div class="flex items-center justify-between max-w-7xl mx-auto px-8 h-18">
    <a href="/" class="z-50">
      <img src="/assets/logo/logotipo_ocre.png" alt="Irene Ovelar" class="h-9 w-auto block" />
    </a>

    <nav class="hidden md:block">
      <ul class="flex gap-10 list-none m-0 p-0">
        <li><a href="/servicios" class="text-sm text-gray-900 no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">Servicios</a></li>
        <li><a href="/biografia" class="text-sm text-gray-900 no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">Biografía</a></li>
        <li><a href="/contacto" class="text-sm text-gray-900 no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">Contacto</a></li>
      </ul>
    </nav>

    <button id="hamburger" aria-label="Abrir menú" aria-expanded="false"
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 bg-transparent border-none cursor-pointer p-0 z-50 relative">
      <span id="bar-top"    class="absolute block w-6 h-px bg-gray-900 transition-all duration-300 -translate-y-[5px]"></span>
      <span id="bar-mid"    class="absolute block w-6 h-px bg-gray-900 transition-all duration-300"></span>
      <span id="bar-bottom" class="absolute block w-6 h-px bg-gray-900 transition-all duration-300 translate-y-[5px]"></span>
    </button>
  </div>
</header>

<!-- Menú fullscreen -->
<div id="mobile-menu"
  class="hidden fixed inset-0 bg-white z-40 flex flex-col md:hidden">

  <!-- Header dentro del menú: logo + X -->
  <div class="flex items-center justify-between px-8 h-18 border-b border-gray-100 shrink-0">
    <a href="/">
      <img src="/assets/logo/logotipo.png" alt="Irene Ovelar" class="h-9 w-auto block" />
    </a>
    <button id="close-menu" aria-label="Cerrar menú"
      class="flex flex-col gap-1.5 bg-transparent border-none cursor-pointer p-1">
      <span class="block w-6 h-px bg-gray-900 translate-y-[3.5px] rotate-45"></span>
      <span class="block w-6 h-px bg-gray-900 -translate-y-[3.5px] -rotate-45"></span>
    </button>
  </div>

  <!-- Links centrados verticalmente -->
  <nav class="flex-1 flex items-center px-8">
    <ul class="list-none m-0 p-0 flex flex-col gap-8 w-full">
      <li>
        <a href="/servicios" class="text-4xl font-light text-gray-900 no-underline hover:opacity-50 transition-opacity duration-200">
          Servicios
        </a>
      </li>
      <li>
        <a href="/biografia" class="text-4xl font-light text-gray-900 no-underline hover:opacity-50 transition-opacity duration-200">
          Biografía
        </a>
      </li>
      <li>
        <a href="/contacto" class="text-4xl font-light text-gray-900 no-underline hover:opacity-50 transition-opacity duration-200">
          Contacto
        </a>
      </li>
    </ul>
  </nav>
</div>

<script>
  const hamburger  = document.getElementById('hamburger');
  const closeBtn   = document.getElementById('close-menu');
  const mobileMenu = document.getElementById('mobile-menu');
  const barTop     = document.getElementById('bar-top');
  const barMid     = document.getElementById('bar-mid');
  const barBottom  = document.getElementById('bar-bottom');

  let isOpen = false;

  function setIcon(open: boolean) {
    if (open) {
      barTop?.classList.add('rotate-45', 'translate-y-0');
      barTop?.classList.remove('-translate-y-[5px]');
      barMid?.classList.add('opacity-0', 'scale-x-0');
      barBottom?.classList.add('-rotate-45', 'translate-y-0');
      barBottom?.classList.remove('translate-y-[5px]');
    } else {
      barTop?.classList.remove('rotate-45', 'translate-y-0');
      barTop?.classList.add('-translate-y-[5px]');
      barMid?.classList.remove('opacity-0', 'scale-x-0');
      barBottom?.classList.remove('-rotate-45', 'translate-y-0');
      barBottom?.classList.add('translate-y-[5px]');
    }
  }

  function openMenu() {
    isOpen = true;
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    hamburger?.setAttribute('aria-expanded', 'true');
    hamburger?.setAttribute('aria-label', 'Cerrar menú');
    document.body.classList.add('overflow-hidden');
    setIcon(true);
  }

  function closeMenu() {
    isOpen = false;
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.setAttribute('aria-label', 'Abrir menú');
    document.body.classList.remove('overflow-hidden');
    setIcon(false);
  }

  hamburger?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  closeBtn?.addEventListener('click', closeMenu);

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>