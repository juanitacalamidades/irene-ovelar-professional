---
---

<footer class="border-t border-arena bg-blanco">
  <div class="max-w-7xl mx-auto px-8 py-14">

    <!-- Main grid: logo / nav / social -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 items-start">

      <!-- Logo -->
      <div class="flex flex-col gap-4">
        <a href="/">
          <img src="/assets/logo/Logo_name_piedra.png" alt="Irene Ovelar" class="h-8 w-auto" />
        </a>
        <p class="text-xs text-piedra tracking-wide leading-relaxed max-w-50">
          Psicóloga sanitaria. Acompañamiento terapéutico personalizado.
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-label="Pie de página">
        <ul class="list-none m-0 p-0 flex flex-col items-start gap-3 md:flex-row md:justify-center md:items-center">
          <li>
            <a href="/servicios" class="text-sm text-grafito no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">
              Servicios
            </a>
          </li>
          <li>
            <a href="/biografia" class="text-sm text-grafito no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">
              Biografía
            </a>
          </li>
          <li>
            <a href="/contacto" class="text-sm text-grafito no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">
              Contacto
            </a>
          </li>
        </ul>
      </nav>

      <!-- Social -->
      <div class="md:text-right">
        <p class="text-xs font-medium text-piedra tracking-widest uppercase mb-4">Sígueme</p>
        <div class="flex items-center gap-5 md:justify-end">
          <a
            href="https://www.instagram.com/ireneovelar_psicologia"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-grafito hover:opacity-50 transition-opacity duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>

          <a
            href="https://wa.me/34637738132"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="text-grafito hover:opacity-50 transition-opacity duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Divider -->
    <div class="border-t border-arena mt-6 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-piedra tracking-wide">
        © {new Date().getFullYear()} Irene Ovelar. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a href="/aviso-legal" class="text-xs text-piedra no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">
          Aviso legal
        </a>
        <a href="/politica-de-cookies" class="text-xs text-piedra no-underline tracking-wide hover:opacity-50 transition-opacity duration-200">
          Política de cookies
        </a>
      </div>
    </div>

  </div>
</footer>
