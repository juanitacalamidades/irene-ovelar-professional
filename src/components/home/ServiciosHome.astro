---
const servicios = [
  {
    num: "01",
    titulo: "Psicoterapia para personas adultas",
    intro: "Acompañamiento en las diversas dificultades que pueden darse en la vida adulta.",
  },
  {
    num: "02",
    titulo: "Terapia para parejas",
    intro: "Intervención en las dificultades que puedan darse en la relación de pareja.",
  },
  {
    num: "03",
    titulo: "Terapia para familias",
    intro: "Para aquellas familias que quieran afrontar sus dificultades teniendo en cuenta las necesidades individuales de cada persona.",
  },
  {
    num: "04",
    titulo: "Atención a la salud mental perinatal",
    intro: "Acompañamiento a madres y padres durante el embarazo, parto, postparto y todo lo que estos procesos conllevan.",
  },
];
---

<section class="servicios-home">
  <div class="container">

    <div class="col-left">
      <p class="eyebrow">Qué ofrezco</p>
      <h2>Un espacio para cada <br />momento vital</h2>
      <p class="intro">
        Trabajo desde un enfoque integrativo y adapto cada proceso
        a la persona y al momento vital en que se encuentra.
      </p>
      <a href="/servicios" class="cta">Ver todos los servicios →</a>
    </div>

    <ul class="col-right" role="list">
      {servicios.map((s) => (
        <li>
          <a href="/servicios" class="item">
            <span class="item-num">{s.num}</span>
            <div class="item-body">
              <p class="item-title">{s.titulo}</p>
              <p class="item-intro">{s.intro}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .servicios-home {
    background: var(--color-crema, #F7F3EF);
    padding: 96px 0;
    width: 100%;
  }

  .container {
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Columna izquierda ── */
  .col-left {
    position: sticky;
    top: 32px;
  }

  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ocre, #C97B5A);
    font-weight: 500;
    margin-bottom: 10px;
  }

  .col-left h2 {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-md), 2.5vw, var(--text-lg));
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-grafito, #3D3530);
    margin-bottom: 20px;
  }

  .intro {
    font-size: var(--text-sm);
    color: var(--color-piedra, #7A6F69);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .cta {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-grafito, #3D3530);
    text-decoration: none;
    padding: 10px 20px;
    border: 0.5px solid rgba(61, 53, 48, 0.35);
    border-radius: 4px;
    transition: background 0.15s, border-color 0.15s;
  }

  .cta:hover {
    background: rgba(61, 53, 48, 0.05);
    border-color: rgba(61, 53, 48, 0.5);
  }

  /* ── Columna derecha ── */
  .col-right {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 0.5px solid rgba(61, 53, 48, 0.15);
    align-items: start;
    text-decoration: none;
    transition: background 0.15s;
  }

  li:first-child .item {
    border-top: 0.5px solid rgba(61, 53, 48, 0.15);
  }

  .item-num {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-ocre, #C97B5A);
    opacity: 0.7;
    padding-top: 3px;
  }

  .item-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-grafito, #3D3530);
    line-height: 1.3;
    margin-bottom: 5px;
    transition: color 0.15s;
  }

  .item:hover .item-title {
    color: var(--color-ocre, #C97B5A);
  }

  .item-intro {
    font-size: var(--text-sm);
    color: var(--color-piedra, #7A6F69);
    line-height: 1.6;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .servicios-home {
      padding: 64px 0;
    }

    .container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .col-left {
      position: static;
    }

    .col-left h2 {
      br { display: none; }
    }
  }

  @media (max-width: 480px) {
    .item {
      grid-template-columns: 28px 1fr;
      gap: 14px;
    }
  }
</style>